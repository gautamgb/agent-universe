# Copy to repository root as `.env` and fill in values.
#
# Docker Compose (from factory/node-16gb or factory/node-32gb):
#   docker compose --env-file ../../.env up -d
# Or rely on `env_file: ../../.env` inside each compose file.

# --- Tailscale IPs (gateway + compute) ---
TAILSCALE_16GB_IP=
TAILSCALE_32GB_IP=

# --- Postgres (compose substitution + LangGraph checkpoint URL on 32GB node) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=seekgb_autonomous_factory_v1
# Used when DATABASE_URL is not set (compute node builds this automatically):
POSTGRES_PORT=5433
POSTGRES_SSLMODE=disable

# Preferred: full Postgres URL for LangGraph checkpointing on the 32GB node (gateway Postgres on 5433):
# DB_URL=postgresql://USER:PASSWORD@TAILSCALE_16GB_IP:5433/POSTGRES_DB?sslmode=disable
# Legacy alias (api.py falls back to this if DB_URL is unset):
# DATABASE_URL=postgresql://USER:PASSWORD@TAILSCALE_16GB_IP:5433/POSTGRES_DB?sslmode=disable

# --- LiteLLM (16GB gateway :4040 → OpenAI-compatible /v1) ---
# Optional on gateway if LiteLLM only routes to Ollama; required for Gemini model_list entries
GEMINI_API_KEY=
# Proxy admin key (must start with sk-); used as LITELLM_API_KEY from the compute node:
LITELLM_MASTER_KEY=
# OpenAI-compatible base (no trailing slash required; code adds /v1):
LITELLM_BASE_URL=http://${TAILSCALE_16GB_IP}:4040
LITELLM_TEMPERATURE=0.2
# LangGraph models — must match a model_name in factory/node-16gb/litellm_config.yaml
# Option 1 (cloud): PRIMARY_MODEL=gemini/gemini-1.5-pro  SCOUT_MODEL=gemini/gemini-1.5-flash
# Option 2 (local): PRIMARY_MODEL=ollama/qwen2.5-coder:7b  SCOUT_MODEL=ollama/qwen2.5-coder:7b
PRIMARY_MODEL=gemini-executive
SCOUT_MODEL=
# Legacy fallback if PRIMARY_MODEL is unset:
# LITELLM_MODEL=gemini-executive
# Gateway LiteLLM → Ollama when using ollama/... models (reachable from 16GB node)
OLLAMA_API_BASE=http://${TAILSCALE_32GB_IP}:11434

# --- Integrations ---
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
# Optional RBAC (comma-separated Slack user IDs). Empty = allow all signed users.
# SLACK_ALLOWED_USER_IDS=U0123ABC,U0456DEF
SCOPED_GITHUB_TOKEN=
# Optional: link in Slack messages to your Streamlit UI
# AGENT_UNIVERSE_DASHBOARD_URL=http://TAILSCALE_32GB_IP:8505

# --- Gateway deploy (factory/node-16gb/deploy.sh) ---
# macOS username on the 16GB Mini (must exist there — run `whoami` on that machine). Tailscale SSH fails if wrong.
NODE_16GB_SSH_USER=
# Single directory name under the remote user's home (default agent-universe → syncs to ~/agent-universe/...). Avoid /opt on macOS without sudo.
# NODE_16GB_REMOTE_ROOT=agent-universe
# Optional: full rsync target (overrides NODE_16GB_SSH_USER build)
# NODE_16GB_RSYNC_DEST=alice@100.x.y.z:agent-universe/factory/node-16gb

# --- Optional: local dev without Postgres checkpoint ---
# CHECKPOINTER=memory

# --- Optional: quality gate max architect revisions before forcing human approval ---
# QUALITY_MAX_REVISIONS=5

# --- Builder (32GB — Aider Docker; used by src/builder_agent.py) ---
AIDER_DOCKER_IMAGE=paulgauthier/aider-full
# Aider --model (e.g. ollama/qwen2.5-coder); Ollama API for the Aider container:
AIDER_MODEL=ollama/qwen2.5-coder
AIDER_OLLAMA_API_BASE=http://host.docker.internal:11434
